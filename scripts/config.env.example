# =============================================================================
# BRCloud FluxGate - Configuration Globale
# =============================================================================
# Copier ce fichier vers config.env et adapter les valeurs a votre serveur.
# Toutes les valeurs marquees <PLACEHOLDER> DOIVENT etre remplies.

# --- Interface reseau principale ---
IFACE="eth0"

# --- Ports exposes ---
SSH_PORT=22
HTTP_PORT=80
HTTPS_PORT=443

# --- Rate limiting nftables (SYN par seconde) ---
NFT_SYN_RATE=50
NFT_SYN_BURST=100

# --- Conntrack ---
CONNTRACK_MAX=262144
CONNTRACK_BUCKETS=65536

# --- SYN cookies / backlog ---
SOMAXCONN=4096
TCP_MAX_SYN_BACKLOG=8192

# --- NGINX rate limiting ---
NGINX_REQ_PER_SEC=30
NGINX_BURST=50
NGINX_MAX_CONN_PER_IP=50
NGINX_UPSTREAM_PORT=8080

# --- Apache mod_reqtimeout ---
APACHE_HEADER_TIMEOUT_MIN=10
APACHE_HEADER_TIMEOUT_MAX=40
APACHE_HEADER_MIN_RATE=500
APACHE_BODY_TIMEOUT_MIN=10
APACHE_BODY_TIMEOUT_MAX=60
APACHE_BODY_MIN_RATE=500

# --- fail2ban ---
F2B_SSH_MAXRETRY=5
F2B_SSH_FINDTIME=600
F2B_SSH_BANTIME=3600
F2B_HTTP_MAXRETRY=100
F2B_HTTP_FINDTIME=60
F2B_HTTP_BANTIME=600

# --- systemd resource control (service web) ---
SVC_CPU_QUOTA=80%
SVC_MEMORY_MAX=2G
SVC_LIMIT_NOFILE=65536
SVC_MAX_CONN_PER_SOURCE=50
SVC_BACKLOG=4096

# --- Traffic shaping (tc) ---
TC_RATE="1gbit"
TC_BURST="32kbit"
TC_LATENCY="50ms"

# --- XDP ---
XDP_ENABLED=false

# --- Monitoring ---
PROMETHEUS_PORT=9090
NODE_EXPORTER_PORT=9100
GRAFANA_PORT=3000
